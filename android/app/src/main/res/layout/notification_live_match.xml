<?xml version="1.0" encoding="utf-8"?>
<!--
  Layout tuỳ chỉnh cho live-update notification (kiểu iOS Live Activity):
  - Hàng 1: logo + tên 2 đội.
  - Hàng 2: tỉ số 2 đội với PHÚT THI ĐẤU ở GIỮA (dễ nhìn hơn kiểu cũ để phút lẫn vào dòng ghi bàn).
  - Hàng 3: người ghi bàn GẦN NHẤT của TỪNG đội (trái = đội nhà, phải = đội khách) — hiện đủ cả
    2 bên nếu cả 2 đội đều đã ghi bàn, thay vì chỉ 1 bàn chung cho cả trận.
  - Hàng 4: thanh tiến trình.
  Dùng với NotificationCompat.DecoratedCustomViewStyle (giữ header hệ thống: icon, tên app,
  thời gian) — bản thân layout này chỉ thay phần NỘI DUNG.
  Màu chữ dùng ?android:attr/textColor* để tự đúng trên nền sáng/tối theo theme hệ thống.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="4dp"
    android:paddingEnd="4dp"
    android:paddingTop="4dp"
    android:paddingBottom="2dp">

    <!-- Hàng 1: logo + tên 2 đội -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/home_crest"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:scaleType="fitCenter"
            android:src="@drawable/team_placeholder"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/home_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/away_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:gravity="end"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <ImageView
            android:id="@+id/away_crest"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:scaleType="fitCenter"
            android:src="@drawable/team_placeholder"
            android:contentDescription="@null" />
    </LinearLayout>

    <!-- Hàng 2: tỉ số - PHÚT THI ĐẤU (ở giữa) - tỉ số -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="horizontal"
        android:gravity="center">

        <TextView
            android:id="@+id/home_score"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="?android:attr/textColorPrimary" />

        <TextView
            android:id="@+id/minute_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:textStyle="bold"
            android:textSize="11sp"
            android:textColor="#FF5A5A" />

        <TextView
            android:id="@+id/away_score"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="start"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="?android:attr/textColorPrimary" />
    </LinearLayout>

    <!-- Hàng 3: người ghi bàn gần nhất của TỪNG đội (trái/phải riêng, chỉ hiện nếu có) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/home_scorer_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="start"
            android:textSize="10sp"
            android:maxLines="5"
            android:ellipsize="end"
            android:textColor="?android:attr/textColorSecondary" />

        <TextView
            android:id="@+id/away_scorer_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:textSize="10sp"
            android:maxLines="5"
            android:ellipsize="end"
            android:textColor="?android:attr/textColorSecondary" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progress_bar"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_marginTop="6dp"
        android:max="90"
        android:progressTint="#4F6BFF"
        android:progressBackgroundTint="#22000000" />

</LinearLayout>
